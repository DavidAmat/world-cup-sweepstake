{
  "name": "world-cup-sweepstake",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:status": "supabase status",
    "db:reset": "supabase db reset",
    "db:diff": "supabase db diff -f",
    "db:push": "supabase db push --linked",
    "types:gen": "supabase gen types typescript --local 2>/dev/null | grep -v '^Connecting to db' > src/lib/supabase/database.types.ts",
    "wc2026:upload": "tsx --env-file=.env.local scripts/wc2026/upload.ts",
    "wc2026:upload:prod": "tsx --env-file=.env.prod scripts/wc2026/upload.ts --confirm-prod",
    "wc2026:clean": "tsx --env-file=.env.local scripts/wc2026/clean-slate.ts",
    "wc2026:clean:prod": "tsx --env-file=.env.prod scripts/wc2026/clean-slate.ts --confirm-prod",
    "wc2026:users": "tsx --env-file=.env.local scripts/wc2026/create-users.ts",
    "wc2026:users:prod": "tsx --env-file=.env.prod scripts/wc2026/create-users.ts --confirm-prod",
    "scoring:smoke": "tsx --env-file=.env.local scripts/scoring/smoke-recalc.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.105.3",
    "country-flag-icons": "^1.6.17",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.14.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.75.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
