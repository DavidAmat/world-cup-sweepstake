# Supabase (rellenado en hito 03)
# Las claves antiguas (anon / service_role) siguen funcionando hasta finales
# de 2026, pero usamos las nuevas (publishable / secret) por defecto.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Slug del torneo activo en la UI por defecto.
NEXT_PUBLIC_DEFAULT_TOURNAMENT_SLUG=wc_2022_test

# Testing: fecha actual simulada para probar el bloqueo de predicciones
# iniciales (vacío = fecha real). Formatos: "2026-06-12",
# "2026-06-12T09:00" (hora Madrid) o ISO con Z/offset. Se sincroniza a
# public.app_settings, así RLS y app usan la misma "ahora".
# Cambiarla requiere reiniciar el dev server (Next lee env al arrancar).
# FECHA_ACTUAL=
